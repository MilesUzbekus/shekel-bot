# Скопируй в .env и заполни. .env в git не попадает (см .gitignore).

# Telegram
TG_TOKEN=                       # токен от @BotFather
TG_ALLOWED_IDS=                 # твой numeric id от @userinfobot (через запятую если несколько)

# Google Sheet
GSHEET_ID=                      # id из ссылки на таблицу
GSHEET_TAB=Лист1                # имя вкладки
GOOGLE_CREDS_JSON=secrets/google.json   # путь к ключу service account

# Прочее
SHEKEL_DB=data/shekel.db
TZ=UTC
